% Tema de cores UFMG/DCC para poster Gemini
% Paleta inspirada no Manual de Marca UFMG (vermelho #C8102E) e identidade DCC

\definecolor{ufmgred}{RGB}{200, 16, 46}
\definecolor{ufmgnavy}{RGB}{29, 49, 66}
\definecolor{ufmglightgray}{RGB}{245, 245, 245}
\definecolor{ufmglightred}{RGB}{255, 242, 244}

% Basic colors
\setbeamercolor{palette primary}{fg=black,bg=white}
\setbeamercolor{palette secondary}{fg=black,bg=white}
\setbeamercolor{palette tertiary}{bg=ufmgnavy,fg=white}
\setbeamercolor{palette quaternary}{fg=black,bg=white}
\setbeamercolor{structure}{fg=ufmgred}

% Headline
\setbeamercolor{headline}{fg=white,bg=ufmgnavy}

% Block
\setbeamercolor{block title}{fg=white,bg=ufmgnavy}
\setbeamercolor{block separator}{bg=ufmgred}
\setbeamercolor{block body}{fg=black,bg=ufmglightgray}

% Alert Block
\setbeamercolor{block alerted title}{fg=white,bg=ufmgred}
\setbeamercolor{block alerted separator}{bg=ufmgred}
\setbeamercolor{block alerted body}{fg=black,bg=ufmglightred}

% Example Block
\setbeamercolor{block example title}{fg=white,bg=ufmgnavy}
\setbeamercolor{block example separator}{bg=ufmgred}
\setbeamercolor{block example body}{fg=black,bg=ufmglightgray}

% Heading
\setbeamercolor{heading}{fg=ufmgnavy}

% Itemize
\setbeamercolor{item}{fg=ufmgred}

% Bibliography
\setbeamercolor{bibliography item}{fg=black}
\setbeamercolor{bibliography entry author}{fg=black}
\setbeamercolor{bibliography entry title}{fg=black}
\setbeamercolor{bibliography entry location}{fg=black}
\setbeamercolor{bibliography entry note}{fg=black}
